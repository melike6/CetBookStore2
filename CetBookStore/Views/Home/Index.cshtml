@model CetBookStore.ViewModels.HomePageViewModel

@{
    ViewData["Title"] = "Home Page";
}

<h2 class="mb-3">Most Commented Books</h2>
<div class="row">
    @foreach (var book in Model.MostCommenteds)
    {
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">@book.Title</h5>
                    <p class="card-text"><strong>Author:</strong> @book.Author</p>
                    <p class="card-text"><strong>Price:</strong> @book.Price.ToString("0.00")</p>

                    @if (book.IsInSale)
                    {
                        <p class="card-text text-danger">
                            <strong>Old Price:</strong> @book.OldPrice.ToString("0.00")
                        </p>
                    }

                    <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id" class="btn btn-outline-secondary btn-sm">
                        Details
                    </a>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="bookId" value="@book.Id" />
                            <button type="submit" class="btn btn-primary btn-sm">Add to Cart</button>
                        </form>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-sm">
                            Login to Add
                        </a>
                    }
                </div>
            </div>
        </div>
    }
</div>

<hr />

