@model CetBookStore.Models.Book

@{
    ViewData["Title"] = "Book Details";
}

<h2>Book Details</h2>

<hr />

<dl class="row">
    <dt class="col-sm-3">Title</dt>
    <dd class="col-sm-9">@Model.Title</dd>

    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.Description</dd>

    <dt class="col-sm-3">Author</dt>
    <dd class="col-sm-9">@Model.Author</dd>

    <dt class="col-sm-3">Publisher</dt>
    <dd class="col-sm-9">@Model.Publisher</dd>

    <dt class="col-sm-3">Page Count</dt>
    <dd class="col-sm-9">@Model.PageCount</dd>

    <dt class="col-sm-3">Price</dt>
    <dd class="col-sm-9">@Model.Price.ToString("0.00")</dd>

    <dt class="col-sm-3">On Sale</dt>
    <dd class="col-sm-9">@(Model.IsInSale ? "Yes" : "No")</dd>

    <dt class="col-sm-3">Previous Price</dt>
    <dd class="col-sm-9">@Model.PreviousPrice.ToString("0.00")</dd>

    <dt class="col-sm-3">Publication Date</dt>
    <dd class="col-sm-9">@Model.PublicationDate.ToShortDateString()</dd>

    <dt class="col-sm-3">Created Date</dt>
    <dd class="col-sm-9">@Model.CreatedDate.ToShortDateString()</dd>

    <dt class="col-sm-3">Category</dt>
    <dd class="col-sm-9">@Model.Category?.Name</dd>
</dl>

@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <form asp-controller="Cart" asp-action="AddToCart" method="post" class="mb-3">
        @Html.AntiForgeryToken()
        <input type="hidden" name="bookId" value="@Model.Id" />
        <button type="submit" class="btn btn-primary">Add to Cart</button>
    </form>
}
else
{
    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary mb-3">
        Login to Add to Cart
    </a>
}

<h4>Add a Comment</h4>

<form asp-action="CommentCreate" method="post" class="mb-4">
    @Html.AntiForgeryToken()
    <input type="hidden" name="BookId" value="@Model.Id" />

    <div class="mb-3">
        <label class="form-label">User Name</label>
        <input name="UserName" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Content</label>
        <textarea name="Content" class="form-control"></textarea>
    </div>

    <button type="submit" class="btn btn-success">Add Comment</button>
</form>

<h4>Comments</h4>

@if (Model.Comments != null && Model.Comments.Any())
{
    @foreach (var comment in Model.Comments)
    {
        <div class="border rounded p-2 mb-2">
            <p class="mb-1">@comment.Content</p>
            <small class="text-muted">@comment.UserName - @comment.CreatedDate.ToShortDateString()</small>
        </div>
    }
}
else
{
    <p>No comments yet.</p>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}